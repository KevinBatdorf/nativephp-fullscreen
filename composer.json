{
    "name": "kevinbatdorf/nativephp-fullscreen",
    "description": "Enter and exit fullscreen (immersive) mode for NativePHP Mobile apps",
    "version": "0.1.0",
    "type": "nativephp-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Kevin Batdorf",
            "email": "kevin@kevinbatdorf.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "nativephp/mobile": "^3.0 || dev-element"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "KevinBatdorf\\Fullscreen\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "KevinBatdorf\\Fullscreen\\FullscreenServiceProvider"
            ]
        },
        "nativephp": {
            "manifest": "nativephp.json"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
